#!/bin/bash
# Scenario 4: Fork Bomb
# Expected: ALERT_FORK_ACCEL (d2 > 0, rate > prev > prev_prev, rate > 50)
# The acceleration invariant fires, NOT a fixed threshold.
set -e
echo "=== SCENARIO 4: Fork Bomb ==="

echo "Launching fork bomb in ct-api..."
docker exec ct-api bash -c '
for i in $(seq 1 2000); do
    /bin/true &
done
wait
' 2>&1 || true
echo "  Exit code: $? (137 = SIGKILL from fork acceleration invariant)"

echo "=== Scenario 4 complete ==="
